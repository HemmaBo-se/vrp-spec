{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "cleanUrls": true,
  "trailingSlash": false,
  "headers": [
    {
      "source": "/contexts/v1",
      "headers": [
        {
          "key": "Content-Type",
          "value": "application/ld+json; charset=utf-8"
        },
        {
          "key": "Cache-Control",
          "value": "public, max-age=3600"
        }
      ]
    },
    {
      "source": "/contexts/v1.jsonld",
      "headers": [
        {
          "key": "Content-Type",
          "value": "application/ld+json; charset=utf-8"
        },
        {
          "key": "Cache-Control",
          "value": "public, max-age=3600"
        }
      ]
    },
    {
      "source": "/schemas/(.*).json",
      "headers": [
        {
          "key": "Content-Type",
          "value": "application/schema+json; charset=utf-8"
        },
        {
          "key": "Cache-Control",
          "value": "public, max-age=3600"
        }
      ]
    },
    {
      "source": "/spec/(.*).md",
      "headers": [
        {
          "key": "Content-Type",
          "value": "text/markdown; charset=utf-8"
        },
        {
          "key": "Cache-Control",
          "value": "public, max-age=3600"
        }
      ]
    },
    {
      "source": "/spec/(.*)",
      "headers": [
        {
          "key": "Content-Type",
          "value": "text/markdown; charset=utf-8"
        },
        {
          "key": "Cache-Control",
          "value": "public, max-age=3600"
        }
      ]
    },
    {
      "source": "/docs/(.*).md",
      "headers": [
        {
          "key": "Content-Type",
          "value": "text/markdown; charset=utf-8"
        },
        {
          "key": "Cache-Control",
          "value": "public, max-age=3600"
        }
      ]
    },
    {
      "source": "/docs/(.*)",
      "headers": [
        {
          "key": "Content-Type",
          "value": "text/markdown; charset=utf-8"
        },
        {
          "key": "Cache-Control",
          "value": "public, max-age=3600"
        }
      ]
    },
    {
      "source": "/examples/(.*).json",
      "headers": [
        {
          "key": "Content-Type",
          "value": "application/json; charset=utf-8"
        },
        {
          "key": "Cache-Control",
          "value": "public, max-age=3600"
        }
      ]
    },
    {
      "source": "/robots.txt",
      "headers": [
        {
          "key": "Content-Type",
          "value": "text/plain; charset=utf-8"
        },
        {
          "key": "Cache-Control",
          "value": "public, max-age=3600"
        }
      ]
    },
    {
      "source": "/llms.txt",
      "headers": [
        {
          "key": "Content-Type",
          "value": "text/plain; charset=utf-8"
        },
        {
          "key": "Cache-Control",
          "value": "public, max-age=3600"
        }
      ]
    },
    {
      "source": "/reference-implementation",
      "headers": [
        {
          "key": "Content-Type",
          "value": "text/html; charset=utf-8"
        },
        {
          "key": "Cache-Control",
          "value": "public, max-age=3600"
        }
      ]
    },
    {
      "source": "/verify",
      "headers": [
        {
          "key": "Content-Type",
          "value": "text/html; charset=utf-8"
        },
        {
          "key": "Cache-Control",
          "value": "public, max-age=3600"
        }
      ]
    },
    {
      "source": "/terms",
      "headers": [
        {
          "key": "Content-Type",
          "value": "text/html; charset=utf-8"
        },
        {
          "key": "Cache-Control",
          "value": "public, max-age=3600"
        }
      ]
    },
    {
      "source": "/sitemap.xml",
      "headers": [
        {
          "key": "Content-Type",
          "value": "application/xml; charset=utf-8"
        },
        {
          "key": "Cache-Control",
          "value": "public, max-age=3600"
        }
      ]
    }
  ],
  "rewrites": [
    {
      "source": "/contexts/v1",
      "destination": "/contexts/v1.jsonld"
    },
    {
      "source": "/reference-implementation",
      "destination": "/reference-implementation.html"
    },
    {
      "source": "/verify",
      "destination": "/verify.html"
    },
    {
      "source": "/docs/first-mover-evidence-memo",
      "destination": "/docs/first-mover-evidence-memo.md"
    },
    {
      "source": "/terms",
      "destination": "/terms.html"
    },
    {
      "source": "/spec/v0.1",
      "destination": "/spec/v0.1.md"
    },
    {
      "source": "/spec/attestations-v0.1",
      "destination": "/spec/attestations-v0.1.md"
    },
    {
      "source": "/docs/interop-and-trust-positioning",
      "destination": "/docs/interop-and-trust-positioning.md"
    },
    {
      "source": "/docs/adr/0002-no-gatekeeper-trust-and-interop",
      "destination": "/docs/adr/0002-no-gatekeeper-trust-and-interop.md"
    },
    {
      "source": "/schemas/attestations-v0.1",
      "destination": "/schemas/attestations-v0.1.schema.json"
    },
    {
      "source": "/schemas/discovery-v0.1",
      "destination": "/schemas/discovery-v0.1.schema.json"
    },
    {
      "source": "/schemas/jwks-v0.1",
      "destination": "/schemas/jwks-v0.1.schema.json"
    },
    {
      "source": "/schemas/verified-stay-offer-v0.1",
      "destination": "/schemas/verified-stay-offer-v0.1.schema.json"
    },
    {
      "source": "/schemas/verified-stay-offer-verification-result-v0.1",
      "destination": "/schemas/verified-stay-offer-verification-result-v0.1.schema.json"
    },
    {
      "source": "/schemas/stayintent-query-v0.1",
      "destination": "/schemas/stayintent-query-v0.1.schema.json"
    },
    {
      "source": "/schemas/stayintent-response-v0.1",
      "destination": "/schemas/stayintent-response-v0.1.schema.json"
    },
    {
      "source": "/spec/:slug",
      "destination": "/spec/:slug.md"
    },
    {
      "source": "/docs/:slug",
      "destination": "/docs/:slug.md"
    }
  ]
}
